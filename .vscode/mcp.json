{
  "servers": {
    "metabokg": {
      "type": "stdio",
      "command": "poetry",
      "args": [
        "run",
        "metabokg-mcp",
        "--db",
        ".metabokg/meta.sqlite",
        "--lancedb",
        ".metabokg/lancedb"
      ],
      "env": {
        "POETRY_VIRTUALENVS_IN_PROJECT": "false"
      }
    },
    "codekg": {
      "type": "stdio",
      "command": "/Users/egs/repos/metabo_kg/.venv/bin/python",
      "args": [
        "-m",
        "code_kg",
        "mcp",
        "--repo",
        "/Users/egs/repos/metabo_kg"
      ]
    }
  }
}
